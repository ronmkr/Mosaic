{
  "name": "mosaic-home",
  "version": "1.1.0",
  "type": "module",
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "build": "zip -r mosaic-home.zip . -x \"*.git*\" \".github*\" \".gitignore\" \"*.md\" \"LICENSE\" \"node_modules/*\"",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "prettier": "^3.8.1"
  },
  "description": "A high-performance, minimalist Chrome extension for managing bookmarks",
  "jest": {
    "setupFiles": [
      "<rootDir>/jest.setup.js"
    ],
    "testEnvironment": "jsdom"
  }
}
